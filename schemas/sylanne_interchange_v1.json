{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sylanne.dev/schemas/interchange/v1",
  "title": "Sylanne Affective State Interchange Document",
  "description": "JSON Schema (draft 2020-12) for Level 1+ conformance serialization as defined in SPEC.md Section 8.",
  "type": "object",
  "required": ["sylanne_version", "schema_version", "session_key", "personality", "state", "scars", "metadata"],
  "additionalProperties": false,
  "properties": {
    "sylanne_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(\\.(0|[1-9]\\d*))?(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "description": "Semver string identifying the Sylanne standard version."
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing schema revision. Current: 1."
    },
    "session_key": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque session identifier."
    },
    "personality": {
      "type": "object",
      "description": "Trait map. All values in [0, 1]. Must contain at least the 5 core traits.",
      "required": ["openness", "warmth", "assertiveness", "stability", "sensitivity"],
      "additionalProperties": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "properties": {
        "openness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "warmth": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "assertiveness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "stability": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "sensitivity": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "state": { "$ref": "#/$defs/EmotionState" },
    "scars": {
      "type": "array",
      "items": { "$ref": "#/$defs/Scar" },
      "description": "Ordered by created_at (ascending). Monotonically non-decreasing in count per A6."
    },
    "hot_pool": {
      "$ref": "#/$defs/HotPool",
      "description": "Level 2 extension. Optional."
    },
    "metadata": {
      "type": "object",
      "description": "Free-form extension data. Implementations may store diagnostics here."
    }
  },
  "$defs": {
    "EmotionVector": {
      "type": "object",
      "required": ["valence", "arousal", "dominance"],
      "additionalProperties": false,
      "properties": {
        "valence": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
        "arousal": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "dominance": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "DeltaVector": {
      "type": "object",
      "description": "Change vector — all components may be negative (represents difference, not absolute state).",
      "required": ["valence", "arousal", "dominance"],
      "additionalProperties": false,
      "properties": {
        "valence": { "type": "number", "minimum": -2.0, "maximum": 2.0 },
        "arousal": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
        "dominance": { "type": "number", "minimum": -1.0, "maximum": 1.0 }
      }
    },
    "EmotionState": {
      "type": "object",
      "required": ["primary", "mood", "confidence", "epoch"],
      "additionalProperties": false,
      "properties": {
        "primary": { "$ref": "#/$defs/EmotionVector" },
        "mood": { "$ref": "#/$defs/EmotionVector" },
        "delta": { "$ref": "#/$defs/DeltaVector" },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "epoch": { "type": "integer", "minimum": 0 }
      }
    },
    "Scar": {
      "type": "object",
      "required": ["dimension", "intensity", "created_at", "source_tag"],
      "additionalProperties": false,
      "properties": {
        "dimension": { "type": "integer", "minimum": 0 },
        "intensity": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "created_at": { "type": "integer", "minimum": 0 },
        "source_tag": { "type": "string", "minLength": 1 }
      }
    },
    "HotPool": {
      "type": "object",
      "required": ["temperature", "volume", "pressure"],
      "additionalProperties": true,
      "properties": {
        "temperature": { "type": "number", "minimum": 0.0 },
        "volume": { "type": "number", "minimum": 0.0 },
        "pressure": { "type": "number", "minimum": 0.0 }
      }
    }
  }
}
